# Redis (Railway injects REDIS_URL automatically when plugin is attached)
REDIS_URL=redis://default:password@host:port

# BallparkPal premium (for automated export fetch — v2)
BALLPARKPAL_EMAIL=
BALLPARKPAL_PASSWORD=
BALLPARKPAL_DATA_DIR=data/ballparkpal

# Odds APIs (future)
FANDUEL_API_KEY=
DRAFTKINGS_API_KEY=

# App
LOG_LEVEL=INFO
TIMEZONE=America/Chicago

# Scheduler — 14:00 UTC == 9:00 AM America/Chicago (CDT)
SCHEDULE_HOUR_UTC=14
SCHEDULE_MINUTE_UTC=0
DISABLE_SCHEDULER=false

# Local cache paths
CACHE_DIR=data/cache
BAT_TRACKING_TTL_DAYS=7
PITCHER_PROFILE_TTL_DAYS=7
